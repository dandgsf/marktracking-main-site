# =============================================================================
# Marktracking Main Site — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com os valores reais.
# NUNCA commite .env.local ou qualquer variante com valores reais.
# =============================================================================

# Supabase — obter em: https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — obter em: https://resend.com/api-keys
RESEND_API_KEY=

# n8n Webhook
N8N_WEBHOOK_SECRET=
N8N_LEAD_WEBHOOK_URL=

# Site
NEXT_PUBLIC_SITE_URL=https://marktracking.com.br
